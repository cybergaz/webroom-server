# ─── Test environment ─────────────────────────────────────────────────────────
# Loaded by `bun --env-file=.env.test test ...`. Points at the local
# docker-compose.test.yml services. Stream creds here are fake — Layer 1 mocks
# the Stream module entirely. For Layer 2 (real Stream), override
# GETSTREAM_API_KEY / GETSTREAM_API_SECRET via shell env or copy them from .env.

PORT=4001
NODE_ENV=test

DATABASE_URL=postgresql://test:test@localhost:5433/webroom_test

JWT_ACCESS_SECRET=test-access-secret-please-do-not-use-in-prod
JWT_REFRESH_SECRET=test-refresh-secret-please-do-not-use-in-prod
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

REDIS_URL=redis://localhost:6380

GETSTREAM_API_KEY=fake-key-mocked-in-layer1
GETSTREAM_API_SECRET=fake-secret-long-enough-to-pass-validation-1234567890
GETSTREAM_CALL_TYPE=audio_room

S3_BUCKET=test-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
