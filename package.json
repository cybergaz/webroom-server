{
  "name": "webroom_server",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:genpush": "drizzle-kit generate && drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "db:seed:test": "bun src/db/seed-test-users.ts",
    "test:up": "docker compose -f docker-compose.test.yml up -d --wait && bun run test:db:push",
    "test:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:push": "DATABASE_URL=postgresql://test:test@localhost:5433/webroom_test bunx drizzle-kit push --force",
    "test:layer1": "bun --env-file=.env.test test test/layer1.e2e.test.ts",
    "test:layer2": "bun --env-file=.env.test test test/layer2.stream-state.test.ts",
    "test:room-101": "bun run test:layer1 && bun run test:layer2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@stream-io/node-sdk": "^0.7.45",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "ioredis": "^5.10.1",
    "nanoid": "^5.1.7",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "module": "src/index.js"
}
